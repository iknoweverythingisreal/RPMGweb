# ===== PRODUCTION PROFILE (template) =====
# Copy to application-prod.properties (gitignored) and fill in real values.
# Activate with: SPRING_PROFILES_ACTIVE=prod

spring.datasource.url=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME
spring.datasource.username=YOUR_DB_USER
spring.datasource.password=YOUR_DB_PASSWORD

spring.jpa.show-sql=false
logging.level.org.springframework.web=INFO
logging.level.org.hibernate.SQL=INFO
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=INFO

# First boot against an empty database: Flyway creates the schema automatically.
# If the database already has tables NOT created by Flyway, uncomment once:
# spring.flyway.baseline-on-migrate=true
