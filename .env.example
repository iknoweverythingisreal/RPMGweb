# Copy to .env and fill in real values. .env is gitignored — never commit it.

# PostgreSQL (JDBC format!)
DB_URL=jdbc:postgresql://db:5432/rpmedia_db
DB_USERNAME=rpmedia_user
DB_PASSWORD=

# Long random string for signing JWT tokens
JWT_SECRET=change-me-to-a-long-random-string

# Teamup integration (optional)
TEAMUP_API_KEY=
TEAMUP_CALENDAR_KEY=
